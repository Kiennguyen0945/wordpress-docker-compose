# =============================================
# WordPress Docker - Environment Config
# =============================================
# Copy this file to .env and edit as needed:
#   cp env.example .env    (Linux / macOS / Git Bash)
#   copy env.example .env  (Windows CMD)

# ── Local IP ─────────────────────────────────
# Linux/macOS: 127.0.0.1
# Windows:     127.0.0.1 (or 127.0.0.1)
# If you use Docker Toolbox on old Windows, use 192.168.99.100
IP=127.0.0.1

# ── WordPress Port ───────────────────────────
# Access WordPress at http://127.0.0.1:80
# Change to 8080 if port 80 is in use
PORT=80

# ── MySQL Password ───────────────────────────
# CHANGE THIS in production / team projects!
DB_ROOT_PASSWORD=password

# ── Database Name ────────────────────────────
DB_NAME=wordpress
