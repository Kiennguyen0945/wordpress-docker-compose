# ──────────────────────────────────────────────
# Environment
# ──────────────────────────────────────────────
.env
.env.local
.env.*

# ──────────────────────────────────────────────
# WordPress - Ignore core + uploads (regenerated)
# ──────────────────────────────────────────────
wp-app/wp-content/uploads/*
!wp-app/wp-content/uploads/.gitkeep

# ──────────────────────────────────────────────
# Database dumps (each dev imports their own)
# ──────────────────────────────────────────────
wp-data/*
!wp-data/.gitkeep
*.sql

# ──────────────────────────────────────────────
# OS files
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ──────────────────────────────────────────────
# Docker
# ──────────────────────────────────────────────
docker-compose.override.yml
